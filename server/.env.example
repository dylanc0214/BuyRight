# KeretaAI server environment
PORT=3000

# Postgres (matches database/setup.sh defaults; pg reads these natively)
PGHOST=localhost
PGPORT=5432
PGDATABASE=keretaai_local
PGUSER=keretaai_user
PGPASSWORD=local_password

# DeepSeek AI (get a key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

FRONTEND_URL=http://localhost:5173
